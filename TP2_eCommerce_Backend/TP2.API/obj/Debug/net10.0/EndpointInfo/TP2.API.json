        "type": "object",
        "properties": {
          "declarationId": {
            "type": "integer",
            "format": "int32"
          },
          "employeeId": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateAgentRequest": {
        "required": [
          "email",
          "employeeId",
          "fullName",
          "password"
        ],
        "type": "object",
        "properties": {
          "employeeId": {
            "minLength": 1,
            "type": "string"
          },
          "fullName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateUserRequestDto": {
        "type": "object",
        "properties": {
          "nas": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "DecideDeclarationRequest": {
        "type": "object",
        "properties": {
          "declarationId": {
            "type": "integer",
            "format": "int32"
          },
          "agentNotes": {
            "type": "string",
            "nullable": true
          },
          "decision": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "InitializeDeclarationRequestDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "taxYear": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SaveDeclarationDraftRequestDto": {
        "type": "object",
        "properties": {
          "declarationId": {
            "type": "integer",
            "format": "int32"
